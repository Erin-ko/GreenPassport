# 綠色循環經濟護照 (Green Cycle Passport) 環境變數範例

# 後端 FastAPI 設定
# 本地開發預設使用 SQLite，若部署到 Render 請置換為 Render PostgreSQL 連線字串
DATABASE_URL=sqlite:///./sql_app.db

# JWT 認證密鑰，請使用隨機生成之安全字串代替
JWT_SECRET=super_secret_key_change_me_in_production

# 認證 Token 的過期時間（分鐘）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# (選填) 圖片上傳服務憑證，若 Demo 階段使用 Base64 儲存則可省略
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
